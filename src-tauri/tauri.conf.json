{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DocConvert",
  "version": "0.1.0",
  "identifier": "com.docconvert",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run fetch-pandoc && npm run bundle-python"
  },
  "app": {
    "windows": [
      {
        "title": "文档转换工具",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/pandoc/": "pandoc/",
      "resources/python/": "python/",
      "../config/": "config/",
      "../plugins/bundled/": "plugins/bundled/"
    }
  }
}
